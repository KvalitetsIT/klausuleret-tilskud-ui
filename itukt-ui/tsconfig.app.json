{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./src/generated/management/*"],
      "@gateway/*": ["./src/generated/gateway/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "generated/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
